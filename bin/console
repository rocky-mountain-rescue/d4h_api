#! /usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"

Bundler.require :tools

require_relative "../lib/d4h"
require "dotenv/load"
require "irb"

Dotenv.load
@client = D4H::API::Client.new(
  api_key: ENV.fetch("D4H_TOKEN"),
  context_id: ENV.fetch("D4H_TEAM_ID").to_i,
)

IRB.start(__FILE__)
